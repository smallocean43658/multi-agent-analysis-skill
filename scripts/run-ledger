    "stop_reason",
    "next_round_question",
]
SYNTHESIS_DECISIONS = {"", "stop", "continue_round_2", "ask_user"}
CROSS_REVIEW_GATE_STATUSES = {"", "clear", "needs_cross_review", "external_verification"}
