RESULT_STATUSES = {"completed", "failed"}
CLOSE_STATUSES = {"closed", "failed", "cancelled"}
ABNORMAL_CLOSE_STATUSES = {"failed", "cancelled"}
TERMINAL_RUN_STATES = {"blocked", "complete"}
TERMINAL_ROUND_STATES = {"blocked", "finalized"}
ROUND_JSON_PATTERN = re.compile(r"round-(\d+)\.json$")
DYNAMIC_STATE_FIELDS = {
