RESOLVED_OUTCOMES = {"accepted", "modified", "rejected", "external-verification"}
INITIAL_REVIEW_QUOTAS = {"single": 1, "dual": 2}
OBJECTIVE_ALIGNMENT_FIELDS = {"status", "rationale", "unmet_requirements"}
OBJECTIVE_ALIGNMENT_STATUSES = {"aligned", "needs_revision"}


def protocol_version(state: dict[str, Any]) -> str:
    return str(state.get("protocol_version") or LEGACY_PROTOCOL)


def review_portfolio_version(state: dict[str, Any]) -> str:
    portfolio = state.get("review_portfolio_version")
    if portfolio is None:
        return CLASSIC_REVIEW_PORTFOLIO
    if portfolio != DECISION_CHAIN_PORTFOLIO:
        raise SystemExit(f"unsupported review portfolio: {portfolio!r}")
    return DECISION_CHAIN_PORTFOLIO


def review_round_one_dimensions(state: dict[str, Any]) -> dict[str, str]:
    if review_portfolio_version(state) == DECISION_CHAIN_PORTFOLIO:
        return DECISION_CHAIN_ROUND_ONE_DIMENSIONS
    return CLASSIC_REVIEW_ROUND_ONE_LENSES


def now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")


def slugify(value: str, fallback: str = "target") -> str:
    slug = re.sub(r"[^a-zA-Z0-9]+", "-", value.strip().lower())
    slug = re.sub(r"-{2,}", "-", slug).strip("-")
    if not slug:
        slug = fallback
    return slug[:48].strip("-") or fallback


def fsync_directory(path: Path) -> None:
    descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def write_json_atomic(path: Path, payload: dict[str, Any]) -> None:
    temporary = path.with_name(f".{path.name}.{uuid4().hex}.tmp")
    data = json.dumps(payload, indent=2, ensure_ascii=False) + "\n"
    with temporary.open("w", encoding="utf-8") as handle:
        handle.write(data)
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(temporary, path)
    fsync_directory(path.parent)


def write_text_atomic(path: Path, data: str) -> None:
    temporary = path.with_name(f".{path.name}.{uuid4().hex}.tmp")
    with temporary.open("w", encoding="utf-8") as handle:
        handle.write(data)
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(temporary, path)
    fsync_directory(path.parent)


@contextmanager
def run_lock(run_dir: Path):
    lock_path = run_dir / ".run-ledger.lock"
    with lock_path.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def maybe_fail(command: str, boundary: str) -> None:
    if os.environ.get("RUN_LEDGER_FAILPOINT") == f"{command}:{boundary}":
        os._exit(97)


def read_json(path: Path) -> Any:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        raise SystemExit(f"missing JSON file: {path}") from None
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON in {path}: {exc}") from None


def round_json_paths(run_dir: Path) -> list[Path]:
    numbered: list[tuple[int, Path]] = []
    for path in run_dir.glob("round-*.json"):
        match = ROUND_JSON_PATTERN.fullmatch(path.name)
        if match is not None:
            numbered.append((int(match.group(1)), path))
    return [path for _, path in sorted(numbered)]


def require_cli_text(value: Any, name: str) -> str:
    if not isinstance(value, str) or not value.strip():
        raise SystemExit(f"{name} must be a non-empty string")
    return value.strip()


def create_unique_run_dir(root: Path, mode: str, title: str) -> tuple[str, Path]:
    stamp = datetime.now().strftime("%Y-%m-%d-%H%M")
    base = f"{stamp}-{mode}-{slugify(title)}-{uuid4().hex[:6]}"

    for index in range(1000):
        run_id = base if index == 0 else f"{base}-{index + 1}"
        candidate = root / run_id
        if not candidate.exists():
            return run_id, candidate

    raise SystemExit(f"could not allocate unique run directory under {root}")


def cleanup_stale_init_directories(root: Path) -> None:
    pattern = re.compile(
        r"\.run-ledger-init-"
        r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    )
    cutoff = time.time() - (24 * 60 * 60)
    for candidate in root.iterdir():
        if not pattern.fullmatch(candidate.name):
            continue
        if candidate.is_symlink() or not candidate.is_dir():
            continue
        try:
            modified_at = candidate.stat().st_mtime
        except FileNotFoundError:
            continue
        if modified_at < cutoff:
            shutil.rmtree(candidate)


def render_brief(args: argparse.Namespace, run_id: str) -> str:
    constraints = args.constraint or []
    constraint_lines = "\n".join(f"- {item}" for item in constraints) if constraints else "- None recorded"
    source_lines = "\n".join(f"- {item}" for item in args.source) if args.source else "- None recorded"
    return f"""# Multi-Agent Analysis Brief

Run ID: {run_id}
Mode: {args.mode}
Target: {args.target}
Objective: {args.objective}
Title: {args.title or args.target}
Created: {now_iso()}
CWD: {args.cwd or ""}

## Constraints

{constraint_lines}

## Source Files

{source_lines}

## Notes

Add any additional context needed by every worker before dispatching the round.
"""


def command_init(args: argparse.Namespace) -> int:
    root = Path(args.root)
    root.mkdir(parents=True, exist_ok=True)
    cleanup_stale_init_directories(root)
    write_text_atomic(root / ".gitignore", "*\n!.gitignore\n")

    title = args.title or args.target
    spawn_tool = require_cli_text(args.spawn_tool, "--spawn-tool")
    wait_tool = require_cli_text(args.wait_tool, "--wait-tool")
    close_tool = require_cli_text(args.close_tool, "--close-tool")
    objective = require_cli_text(args.objective, "--objective")
    run_id, run_dir = create_unique_run_dir(root, args.mode, title)
    created_at = now_iso()

    state = {
        "version": VERSION,
        "protocol_version": ADAPTIVE_PROTOCOL,
        "run_id": run_id,
        "mode": args.mode,
        "target_overlay": args.target_overlay,
        "status": "initialized",
        "target": args.target,
        "objective": objective,
        "title": title,
        "created_at": created_at,
        "root": str(root),
        "run_dir": str(run_dir),
        "cwd": args.cwd or "",
        "tooling": {
            "spawn": spawn_tool,
            "wait": wait_tool,
            "close": close_tool,
        },
        "expected_agents_per_round": EXPECTED_AGENTS_PER_ROUND,
        "round_cap": ROUND_CAP,
        "current_round": 1,
        "last_finalized_round": 0,
        "next_action": "prepare_round",
        "updated_at": created_at,
    }
    if args.mode == "review":
        state["review_portfolio_version"] = DECISION_CHAIN_PORTFOLIO

    staging = root / f".run-ledger-init-{uuid4()}"
    staging.mkdir(parents=False, exist_ok=False)
    try:
        write_text_atomic(staging / "brief.md", render_brief(args, run_id))
        write_text_atomic(staging / "ledger.md", render_ledger(state, []))
        maybe_fail("init", "after-ledger")
        write_json_atomic(staging / "state.json", state)
        maybe_fail("init", "after-state")
        fsync_directory(staging)
        os.rename(staging, run_dir)
        fsync_directory(root)
    except BaseException:
        if staging.exists():
            shutil.rmtree(staging)
        raise

    print(run_dir)
    return 0


def require_text(value: Any, key: str, index: int) -> str:
    if not isinstance(value, str) or not value.strip():
        raise SystemExit(f"assignment {index} must include non-empty string {key!r}")
    return value


def validate_unique_lenses(assignments: list[dict[str, Any]]) -> None:
    lenses = [item["lens"] for item in assignments]
    if len(set(lenses)) != len(lenses):
        raise SystemExit("assignments must use six unique lens labels")


def validate_divergent_round_one(assignments: list[dict[str, Any]]) -> None:
    expected_slots = [f"D{index}" for index in range(1, ROUND_ONE_ASSIGNMENT_COUNT + 1)]
    actual_slots = [item["slot"] for item in assignments]
    if actual_slots != expected_slots:
        raise SystemExit(
            "divergent-analysis round 1 slots must be exactly "
            f"{', '.join(expected_slots)} in order"
        )
    validate_unique_lenses(assignments)
    for index, item in enumerate(assignments, start=1):
        for key in DIVERGENT_ROUND_ONE_REQUIRED_KEYS:
            require_text(item.get(key), key, index)


def validate_round_one_lenses(
    assignments: list[dict[str, Any]], mode: str, review_dimensions: dict[str, str] | None
) -> None:
    if mode == "divergent-analysis":
        validate_divergent_round_one(assignments)
        return

    if review_dimensions is None:
        raise SystemExit("review round 1 requires a review portfolio")
    expected = review_dimensions
    expected_slots = list(expected)
    actual_slots = [item["slot"] for item in assignments]
    if actual_slots != expected_slots:
        raise SystemExit(
            f"{mode} round 1 slots must be exactly {', '.join(expected_slots)} in order"
        )
    for item in assignments:
        expected_lens = expected[item["slot"]]
        if item["lens"] != expected_lens:
            raise SystemExit(
                f"{item['slot']} lens must be {expected_lens!r}, got {item['lens']!r}"
            )


def validate_target_overlay(
    assignments: list[dict[str, Any]],
    mode: str,
    round_number: int,
    target_overlay: str,
    review_portfolio: str | None,
) -> None:
    if target_overlay not in TARGET_OVERLAYS:
        raise SystemExit(f"unsupported target overlay: {target_overlay!r}")

    overlay_fields = {"overlay_checks", "overlay_role"}
    if not target_overlay:
        for index, item in enumerate(assignments, start=1):
            unexpected = overlay_fields.intersection(item)
            if unexpected:
                raise SystemExit(
                    f"assignment {index} cannot include overlay fields without a target overlay"
                )
        return

    if round_number != 1:
        for index, item in enumerate(assignments, start=1):
            unexpected = overlay_fields.intersection(item)
            if unexpected:
                raise SystemExit(
                    f"assignment {index} cannot include overlay fields outside round 1"
                )
        return

    if mode == "review":
        checks = (
            ENGINEERING_OVERLAY_CHECKS
            if review_portfolio == DECISION_CHAIN_PORTFOLIO
            else LEGACY_ENGINEERING_OVERLAY_CHECKS
        )
        for index, item in enumerate(assignments, start=1):
            if "overlay_role" in item:
                raise SystemExit("engineering review assignments must not include overlay_role")
            expected_checks = checks[item["slot"]]
            if item.get("overlay_checks") != expected_checks:
                raise SystemExit(
                    f"{item['slot']} overlay_checks must equal its engineering slot mapping"
                )
        return

    engineering_assignments = [
        item for item in assignments if item.get("overlay_role") == "engineering-feasibility"
    ]
    if len(engineering_assignments) != 1:
        raise SystemExit(
            "engineering divergent round 1 requires exactly one engineering-feasibility role"
        )
    for index, item in enumerate(assignments, start=1):
        if item in engineering_assignments:
            if item.get("overlay_checks") != DIVERGENT_ENGINEERING_CHECKS:
                raise SystemExit(
                    "engineering-feasibility overlay_checks must equal the divergent engineering mapping"
                )
        elif overlay_fields.intersection(item):
            raise SystemExit(
                f"assignment {index} must not include engineering overlay fields"
            )


def validate_assignments(
    raw: Any,
    mode: str,
    round_number: int,
    protocol: str,
    target_overlay: str,
    review_dimensions: dict[str, str] | None,
    review_portfolio: str | None,
) -> list[dict[str, Any]]:
    if not isinstance(raw, list):
        raise SystemExit("assignments JSON must be an array")
    assignments = raw
    if round_number == 1 or protocol == LEGACY_PROTOCOL:
        if len(assignments) != ROUND_ONE_ASSIGNMENT_COUNT:
            raise SystemExit("assignments JSON must contain exactly six entries")
    elif not 1 <= len(assignments) <= FOLLOWUP_SEAT_LIMIT:
        raise SystemExit("adaptive follow-up assignments must contain between one and six entries")

    validated: list[dict[str, Any]] = []
    for index, item in enumerate(assignments, start=1):
        if not isinstance(item, dict):
            raise SystemExit(f"assignment {index} must be an object")
        validated_item = dict(item)
        for key in ["slot", "lens", "question"]:
            validated_item[key] = require_text(validated_item.get(key), key, index)
        validated.append(validated_item)
    slots = [item["slot"] for item in validated]
    if len(set(slots)) != len(slots):
        raise SystemExit("assignments must use unique slot labels")
    if round_number == 1:
        validate_round_one_lenses(validated, mode, review_dimensions)
    validate_target_overlay(validated, mode, round_number, target_overlay, review_portfolio)
    return validated


def markdown_escape(value: Any) -> str:
    return str(value).replace("|", "\\|").replace("\n", " ")


def non_empty_text(value: Any) -> str:
    if value is None:
        return ""
    return str(value).strip()


def markdown_list(value: Any) -> str:
    if not isinstance(value, list):
        return "- None recorded"
    lines = [f"- {non_empty_text(item)}" for item in value if non_empty_text(item)]
    return "\n".join(lines) if lines else "- None recorded"


def markdown_field(value: Any) -> str:
    text = non_empty_text(value)
    return text if text else "None recorded"


def markdown_cross_review_targets(value: Any) -> str:
    if not isinstance(value, list):
        return "- None recorded"
    lines: list[str] = []
    for item in value:
        if not isinstance(item, dict):
            continue
        target_id = non_empty_text(item.get("target_id"))
        if not target_id:
            continue
        lines.append(f"- Target {markdown_escape(target_id)}")
        source_slot = non_empty_text(item.get("source_slot"))
        if source_slot:
            lines.append(f"  - Source slot: {markdown_escape(source_slot)}")
        disposition = non_empty_text(item.get("disposition"))
        if disposition:
            lines.append(f"  - Disposition: {markdown_escape(disposition)}")
        review_policy = non_empty_text(item.get("review_policy"))
        if review_policy:
            lines.append(f"  - Review policy: {markdown_escape(review_policy)}")
        conflict_ref = non_empty_text(item.get("conflict_ref"))
        if conflict_ref:
            lines.append(f"  - Conflict ref: {markdown_escape(conflict_ref)}")
        claim = non_empty_text(item.get("claim"))
        if claim:
            lines.append(f"  - Claim: {markdown_escape(claim)}")
        why = non_empty_text(item.get("why_decision_critical"))
        if why:
            lines.append(f"  - Why decision critical: {markdown_escape(why)}")
    return "\n".join(lines) if lines else "- None recorded"


def markdown_cross_review_outcomes(value: Any) -> str:
    if not isinstance(value, list):
        return "- None recorded"
    lines: list[str] = []
    for item in value:
        if not isinstance(item, dict):
            continue
        target_id = non_empty_text(item.get("target_id"))
        if not target_id:
            continue
        lines.append(f"- Outcome for {markdown_escape(target_id)}")
        status = non_empty_text(item.get("status"))
        if status:
            lines.append(f"  - Status: {markdown_escape(status)}")
        rationale = non_empty_text(item.get("rationale"))
        if rationale:
            lines.append(f"  - Rationale: {markdown_escape(rationale)}")
    return "\n".join(lines) if lines else "- None recorded"


def markdown_object_list(value: Any) -> str:
    if not isinstance(value, list):
        return "- None recorded"
    lines: list[str] = []
    for item in value:
        if not isinstance(item, dict):
            continue
        parts = [f"{key}={item[key]}" for key in sorted(item) if non_empty_text(item.get(key))]
        if parts:
            lines.append("- " + "; ".join(parts))
    return "\n".join(lines) if lines else "- None recorded"


def markdown_objective_alignment(value: Any) -> str:
    if not isinstance(value, dict):
        return "None recorded"
    status = markdown_field(value.get("status"))
    rationale = markdown_field(value.get("rationale"))
    unmet_requirements = markdown_list(value.get("unmet_requirements"))
    return (
        f"Status: {status}\n\n"
        f"Rationale: {rationale}\n\n"
        "Unmet Requirements:\n\n"
        f"{unmet_requirements}"
    )


def render_round_markdown(round_doc: dict[str, Any]) -> str:
    rows = [
        "| Slot | Lens | Question | Agent ID | Result | Close |",
        "|---|---|---|---|---|---|",
    ]
    result_lines: list[str] = []
    for item in round_doc["assignments"]:
        rows.append(
            "| {slot} | {lens} | {question} | {agent_id} | {result_status} | {close_status} |".format(
                slot=markdown_escape(item["slot"]),
                lens=markdown_escape(item["lens"]),
                question=markdown_escape(item["question"]),
                agent_id=markdown_escape(item.get("agent_id") or ""),
                result_status=markdown_escape(item.get("result_status") or "pending"),
                close_status=markdown_escape(item.get("close_status") or "pending"),
            )
        )
        summary = non_empty_text(item.get("result_summary"))
        if summary or item.get("result_status") not in (None, "", "pending"):
            result_lines.append(
                "- {slot} ({status}): {summary}".format(
                    slot=item["slot"],
                    status=item.get("result_status") or "pending",
                    summary=summary or "No summary recorded",
                )
            )

    synthesis = round_doc.get("synthesis", {})
    result_body = "\n".join(result_lines) if result_lines else "- None recorded"

    return f"""# Round {round_doc["round"]:02d}

Status: {round_doc["status"]}
Created: {round_doc["created_at"]}
Incoming backlog: {", ".join(round_doc.get("incoming_backlog_ids", [])) or "None"}
Active targets: {", ".join(round_doc.get("active_target_ids", [])) or "None"}

## Assignments

{chr(10).join(rows)}

## Results

{result_body}

## Synthesis

### Convergence

{markdown_list(synthesis.get("convergence"))}

### Disagreement

{markdown_list(synthesis.get("disagreement"))}

### Critical Disagreements

{markdown_list(synthesis.get("critical_disagreements"))}

### Cannot Verify

{markdown_list(synthesis.get("cannot_verify"))}

### High Impact Low Evidence

{markdown_list(synthesis.get("high_impact_low_evidence"))}

### Action List

{markdown_list(synthesis.get("action_list"))}

### Objective Alignment

{markdown_objective_alignment(synthesis.get("objective_alignment"))}

### Cross Review Gate Status

{markdown_field(synthesis.get("cross_review_gate_status"))}

### Cross Review Targets

{markdown_cross_review_targets(synthesis.get("cross_review_targets"))}

### Cross Review Outcomes

{markdown_cross_review_outcomes(synthesis.get("cross_review_outcomes"))}

### Expected Value Of Another Round

{markdown_field(synthesis.get("expected_value_of_another_round"))}

### Decision

{markdown_field(synthesis.get("next_round_decision"))}

### Stop Reason

{markdown_field(synthesis.get("stop_reason"))}

### Next Round Question

{markdown_field(synthesis.get("next_round_question"))}
"""


def canonical_json_digest(payload: Any) -> str:
    data = json.dumps(
        payload,
        sort_keys=True,
        separators=(",", ":"),
        ensure_ascii=False,
    ).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def event_id(
    round_number: int,
    slot: str,
    event: str,
    content_digest: str = "",
) -> str:
    suffix = f"-{content_digest[:12]}" if content_digest else ""
    return f"r{round_number:02d}-{slot}-{event}{suffix}"


def event_content(
    round_number: int,
    slot: str,
    event: str,
    *,
    status: str = "",
    agent_id: str = "",
    summary: str = "",
    content_digest: str = "",
    **extra: Any,
) -> dict[str, Any]:
    content = {
        "event_id": event_id(round_number, slot, event, content_digest),
        "slot": slot,
        "event": event,
        "status": status,
        "agent_id": agent_id,
        "summary": summary,
        **extra,
    }
    if content_digest:
        content["content_digest"] = content_digest
    return content


def find_event(round_doc: dict[str, Any], identifier: str) -> dict[str, Any] | None:
    for item in round_doc.get("events", []):
        if item.get("event_id") == identifier:
            return item
    return None


def event_without_timestamp(item: dict[str, Any]) -> dict[str, Any]:
    return {
        key: value
        for key, value in item.items()
        if key not in {"recorded_at", "migrated_snapshot"}
    }


def require_event_replay(round_doc: dict[str, Any], requested: dict[str, Any]) -> None:
    existing = find_event(round_doc, str(requested["event_id"]))
    if existing is None:
        raise SystemExit(
            f"canonical event {requested['event_id']!r} is missing for an already committed update"
        )
    if event_without_timestamp(existing) != requested:
        raise SystemExit(f"conflicting replay for event_id={requested['event_id']!r}")


def append_canonical_event(
    round_doc: dict[str, Any],
    requested: dict[str, Any],
    recorded_at: str,
) -> None:
    existing = find_event(round_doc, str(requested["event_id"]))
    if existing is not None:
        if event_without_timestamp(existing) == requested:
            raise SystemExit(f"duplicate canonical event_id={requested['event_id']!r}")
        raise SystemExit(f"conflicting replay for event_id={requested['event_id']!r}")
    round_doc.setdefault("events", []).append({**requested, "recorded_at": recorded_at})


def require_legacy_timestamp(value: Any, round_number: int, field: str) -> str:
    if not isinstance(value, str) or not value.strip():
        raise SystemExit(
            f"cannot normalize round-{round_number:02d}: missing {field}; "
            "legacy event timestamp derivation is ambiguous"
        )
    return value


def legacy_synthesis_has_recorded_state(round_doc: dict[str, Any]) -> bool:
    synthesis = round_doc.get("synthesis")
    if not isinstance(synthesis, dict):
        return synthesis not in (None, {})
    finalization_fields = {"next_round_decision", "stop_reason", "next_round_question"}
    return any(
        key not in finalization_fields and value not in (None, "", [])
        for key, value in synthesis.items()
    )


def validate_legacy_synthesis_evidence(
    round_doc: dict[str, Any], round_number: int
) -> str | None:
    synthesis_recorded_at = round_doc.get("synthesis_recorded_at")
    if round_doc.get("status") == "finalized":
        if not lifecycle_complete(round_doc):
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: finalized lifecycle is incomplete"
            )
        if not synthesis_is_ready(round_doc, require_objective_alignment=False):
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: finalized synthesis is not ready"
            )
        return require_legacy_timestamp(
            synthesis_recorded_at,
            round_number,
            "synthesis_recorded_at",
        )
    if synthesis_recorded_at not in (None, ""):
        return require_legacy_timestamp(
            synthesis_recorded_at,
            round_number,
            "synthesis_recorded_at",
        )
    if legacy_synthesis_has_recorded_state(round_doc):
        return require_legacy_timestamp(
            synthesis_recorded_at,
            round_number,
            "synthesis_recorded_at",
        )
    return None


def upgrade_legacy_event_backfill(
    round_doc: dict[str, Any], round_number: int
) -> dict[str, Any]:
    synthesis_timestamp = validate_legacy_synthesis_evidence(round_doc, round_number)
    normalized = dict(round_doc)
    events = [dict(item) for item in round_doc.get("events", [])]
    if synthesis_timestamp is not None:
        synthesis = validate_synthesis_payload(round_doc.get("synthesis"))
        snapshot_summary = f"fields={','.join(sorted(synthesis))}"
        snapshots = [
            item
            for item in events
            if item.get("event") == "synthesis" and item.get("summary") == snapshot_summary
        ]
        if snapshots:
            snapshots[0]["migrated_snapshot"] = True
    normalized["events"] = events
    normalized.pop("legacy_event_backfill", None)
    return normalized


def normalize_legacy_round(round_doc: dict[str, Any]) -> dict[str, Any] | None:
    raw_events = round_doc.get("events")
    canonical_event_format = False
    if raw_events is None:
        legacy_events: list[dict[str, Any]] = []
    elif not isinstance(raw_events, list):
        raise SystemExit("round events must be an array")
    else:
        if any(not isinstance(item, dict) for item in raw_events):
            raise SystemExit("round events must contain objects")
        has_event_ids = [bool(item.get("event_id")) for item in raw_events]
        canonical_event_format = bool(has_event_ids) and all(has_event_ids)
        if any(has_event_ids):
            if not canonical_event_format:
                raise SystemExit("cannot normalize a round containing mixed canonical and legacy events")
        legacy_events = raw_events

    try:
        round_number = int(round_doc["round"])
    except (KeyError, TypeError, ValueError) as exc:
        raise SystemExit("legacy round JSON must include an integer round number") from exc

    if canonical_event_format:
        if round_doc.get("legacy_event_backfill") is True:
            return upgrade_legacy_event_backfill(round_doc, round_number)
        return None

    normalized = dict(round_doc)
    raw_assignments = round_doc.get("assignments")
    if not isinstance(raw_assignments, list):
        raise SystemExit(f"round-{round_number:02d} assignments must be an array")
    assignments = [dict(item) if isinstance(item, dict) else item for item in raw_assignments]
    if any(not isinstance(item, dict) for item in assignments):
        raise SystemExit(f"round-{round_number:02d} assignments must contain objects")
    normalized["assignments"] = assignments

    created_at = require_legacy_timestamp(round_doc.get("created_at"), round_number, "created_at")
    prepare = event_content(
        round_number,
        "round",
        "prepare",
        status="planned",
        summary="prepared exactly six assignments",
        plan_digest=round_plan_digest(assignments),
    )
    canonical_events = [{**prepare, "recorded_at": created_at}]

    assignments_by_slot: dict[str, dict[str, Any]] = {}
    expected_lifecycle: set[tuple[str, str]] = set()
    lifecycle_fields = {
        "spawn": ("spawn_status", "spawn_recorded_at"),
        "result": ("result_status", "result_recorded_at"),
        "close": ("close_status", "close_recorded_at"),
    }
    for assignment in assignments:
        slot = str(assignment.get("slot") or "")
        if not slot or slot in assignments_by_slot:
            raise SystemExit(f"round-{round_number:02d} has invalid or duplicate assignment slots")
        assignments_by_slot[slot] = assignment
        for event, (status_field, _) in lifecycle_fields.items():
            if assignment.get(status_field) not in (None, "", "pending"):
                expected_lifecycle.add((event, slot))

    seen_lifecycle: set[tuple[str, str]] = set()
    for legacy_event in legacy_events:
        event = str(legacy_event.get("event") or "")
        slot = str(legacy_event.get("slot") or "")
        if event not in lifecycle_fields:
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: unsupported legacy event {event!r}"
            )
        key = (event, slot)
        if key in seen_lifecycle:
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: duplicate legacy {event} event for {slot}"
            )
        seen_lifecycle.add(key)
        assignment = assignments_by_slot.get(slot)
        if assignment is None or key not in expected_lifecycle:
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: legacy {event} event conflicts with {slot}"
            )

        status_field, timestamp_field = lifecycle_fields[event]
        status = str(assignment.get(status_field) or "")
        validate_record_status(event, status)
        if str(legacy_event.get("status") or "") != status:
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: legacy {event} status conflicts with {slot}"
            )
        recorded_at = require_legacy_timestamp(
            assignment.get(timestamp_field),
            round_number,
            f"assignments[{slot!r}].{timestamp_field}",
        )
        legacy_recorded_at = legacy_event.get("recorded_at")
        if legacy_recorded_at not in (None, "", recorded_at):
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: legacy {event} timestamp conflicts with {slot}"
            )

        agent_id = str(assignment.get("agent_id") or "")
        if str(legacy_event.get("agent_id") or "") != agent_id:
            raise SystemExit(
                f"cannot normalize round-{round_number:02d}: legacy {event} agent_id conflicts with {slot}"
            )
        legacy_summary = str(legacy_event.get("summary") or "")
        if event == "result":
            result_summary = str(assignment.get("result_summary") or "")
            if legacy_summary != result_summary:
                raise SystemExit(
                    f"cannot normalize round-{round_number:02d}: legacy result summary conflicts with {slot}"
                )
            summary = result_summary
        else:
            summary = legacy_summary
        canonical = event_content(
            round_number,
            slot,
            event,
            status=status,
            agent_id=agent_id,
            summary=summary,
        )
        canonical_events.append({**canonical, "recorded_at": recorded_at})

    missing_lifecycle = expected_lifecycle - seen_lifecycle
    if missing_lifecycle:
        event, slot = sorted(missing_lifecycle)[0]
        raise SystemExit(
            f"cannot normalize round-{round_number:02d}: missing legacy {event} event for {slot}; "
            "event content derivation is ambiguous"
        )

    synthesis_timestamp = validate_legacy_synthesis_evidence(round_doc, round_number)
    if synthesis_timestamp is not None:
        synthesis = validate_synthesis_payload(round_doc.get("synthesis"))
        digest = canonical_json_digest(synthesis)
        synthesis_event = event_content(
            round_number,
            "round",
            "synthesis",
            summary=f"fields={','.join(sorted(synthesis))}",
            content_digest=digest,
            migrated_snapshot=True,
        )
        canonical_events.append({**synthesis_event, "recorded_at": synthesis_timestamp})

    round_status = str(round_doc.get("status") or "")
    if round_status in TERMINAL_ROUND_STATES:
        finalized_at = require_legacy_timestamp(
            round_doc.get("finalized_at"),
            round_number,
            "finalized_at",
        )
        synthesis = round_doc.get("synthesis")
        if not isinstance(synthesis, dict):
            raise SystemExit(f"round-{round_number:02d} synthesis must be an object")
        decision = str(synthesis.get("next_round_decision") or "")
        blocked = round_status == "blocked"
        summary_field = "stop_reason" if blocked or decision == "stop" else "next_round_question"
        finalization = event_content(
            round_number,
            "round",
            "finalize",
            status=round_status,
            summary=str(synthesis.get(summary_field) or ""),
            decision=decision,
            blocked=blocked,
        )
        canonical_events.append({**finalization, "recorded_at": finalized_at})
    elif round_doc.get("finalized_at") not in (None, ""):
        raise SystemExit(
            f"cannot normalize round-{round_number:02d}: finalized_at exists for non-terminal status"
        )

    normalized["events"] = canonical_events
    normalized["updated_at"] = canonical_events[-1]["recorded_at"]
    return normalized


def normalize_legacy_rounds(run_dir: Path) -> None:
    for path in round_json_paths(run_dir):
        round_doc = read_json(path)
        if not isinstance(round_doc, dict):
            raise SystemExit(f"round JSON must contain an object: {path}")
        normalized = normalize_legacy_round(round_doc)
        if normalized is not None:
            write_json_atomic(path, normalized)


def load_all_rounds(run_dir: Path) -> list[dict[str, Any]]:
    rounds: list[dict[str, Any]] = []
    for path in round_json_paths(run_dir):
        item = read_json(path)
        if not isinstance(item, dict):
            raise SystemExit(f"round JSON must contain an object: {path}")
        rounds.append(item)
    return rounds


def load_followup_rounds(run_dir: Path) -> list[dict[str, Any]]:
    return [
        round_doc
        for round_doc in load_all_rounds(run_dir)
        if int(round_doc["round"]) >= 2
    ]


def canonical_target(run_dir: Path, target_id: str) -> dict[str, Any]:
    matches = [
        item
        for round_doc in load_all_rounds(run_dir)
        for item in (round_doc.get("synthesis") or {}).get("cross_review_targets", [])
        if item.get("target_id") == target_id
    ]
    if len(matches) != 1:
        raise SystemExit(f"expected one canonical target {target_id!r}")
    return matches[0]


def completed_review_count(run_dir: Path, target_id: str) -> int:
    return sum(
        1
        for round_doc in load_followup_rounds(run_dir)
        for assignment in round_doc.get("assignments", [])
        if assignment.get("target_id") == target_id
        and assignment.get("result_status") == "completed"
    )


def last_outcome(run_dir: Path, target_id: str) -> str:
    status = ""
    for round_doc in load_followup_rounds(run_dir):
        for outcome in (round_doc.get("synthesis") or {}).get("cross_review_outcomes", []):
            if outcome.get("target_id") == target_id:
                status = str(outcome.get("status") or "")
    return status


def pending_backlog_from_rounds(rounds: list[dict[str, Any]]) -> list[str]:
    targets: list[str] = []
    origins: dict[str, int] = {}
    for round_doc in rounds:
        synthesis = round_doc.get("synthesis") or {}
        for item in synthesis.get("cross_review_targets", []):
            target_id = str(item.get("target_id") or "")
            if target_id in origins:
                raise SystemExit(f"duplicate canonical target {target_id!r}")
            origins[target_id] = int(round_doc["round"])
            if item.get("disposition") == "pending":
                targets.append(target_id)
        outcomes = {
            item["target_id"]: item["status"]
            for item in synthesis.get("cross_review_outcomes", [])
        }
        targets = [
            target_id
            for target_id in targets
            if outcomes.get(target_id) not in RESOLVED_OUTCOMES
        ]
    return targets


def pending_backlog(run_dir: Path) -> list[str]:
    return pending_backlog_from_rounds(load_all_rounds(run_dir))


def initial_review_quota(run_dir: Path, target_id: str) -> int:
    policy = canonical_target(run_dir, target_id)["review_policy"]
    try:
        return INITIAL_REVIEW_QUOTAS[policy]
    except KeyError:
        raise SystemExit(f"target {target_id!r} has invalid review_policy {policy!r}") from None


def seats_required(run_dir: Path, target_id: str) -> int:
    initial_quota = initial_review_quota(run_dir, target_id)
    used = completed_review_count(run_dir, target_id)
    if used == 0:
        return initial_quota
    if last_outcome(run_dir, target_id) == "unresolved" and used == initial_quota:
        return 1
    return 0


def expected_followup_batch(run_dir: Path) -> list[tuple[str, int]]:
    selected: list[tuple[str, int]] = []
    used = 0
    for target_id in pending_backlog(run_dir):
        seats = seats_required(run_dir, target_id)
        if seats == 0:
            raise SystemExit(
                f"target {target_id!r} exhausted textual review; resolve or externalize it"
            )
        if used + seats > FOLLOWUP_SEAT_LIMIT:
            break
        selected.append((target_id, seats))
        used += seats
    return selected


def has_external_verification(rounds: list[dict[str, Any]]) -> bool:
    for round_doc in rounds:
        synthesis = round_doc.get("synthesis") or {}
        if any(
            item.get("disposition") == "external_verification"
            for item in synthesis.get("cross_review_targets", [])
        ):
            return True
        if any(
            item.get("status") == "external-verification"
            for item in synthesis.get("cross_review_outcomes", [])
        ):
            return True
    return False


def require_unused_spawned_agent_id(
    run_dir: Path,
    round_number: int,
    slot: str,
    agent_id: str,
) -> None:
    for stored_round in load_all_rounds(run_dir):
        for event in stored_round.get("events", []):
            if (
                event.get("event") == "spawn"
                and event.get("status") == "spawned"
                and event.get("agent_id") == agent_id
                and (
                    int(stored_round["round"]) != round_number
                    or event.get("slot") != slot
                )
            ):
                raise SystemExit(
                    f"spawned agent_id {agent_id!r} is already recorded for "
                    f"round {stored_round['round']} slot {event.get('slot')!r}"
                )


def adaptive_gate_and_decision(
    round_number: int,
    backlog: list[str],
    has_external: bool,
) -> tuple[str, str]:
    if backlog:
        return (
            "needs_cross_review",
            "continue_round_2" if round_number == 1 else "ask_user",
        )
    if has_external:
        return "external_verification", "stop"
    return "clear", "stop"


def derive_dynamic_state(
    state: dict[str, Any],
    rounds: list[dict[str, Any]],
) -> dict[str, Any]:
    if not rounds:
        return {
            "status": "initialized",
            "current_round": 1,
            "last_finalized_round": 0,
            "next_action": "prepare_round",
            "updated_at": state.get("updated_at") or state["created_at"],
        }
    latest = rounds[-1]
    finalized = [item for item in rounds if item.get("status") == "finalized"]
    if latest.get("status") == "blocked":
        status, next_action = "blocked", "blocked"
    elif latest.get("status") == "finalized":
        decision = (latest.get("synthesis") or {}).get("next_round_decision")
        if decision == "stop":
            status, next_action = "complete", "complete"
        elif decision == "ask_user":
            status, next_action = "awaiting_user", "ask_user"
        else:
            status, next_action = "round_finalized", "prepare_round"
    else:
        counts = round_counts(latest)
        expected = expected_agents(latest)
        if counts["planned_dispatches"]:
            next_action = "resolve_planned_dispatch"
        elif has_lifecycle_failure(latest) and counts["open_spawned"]:
            next_action = "close_workers"
        elif has_lifecycle_failure(latest):
            next_action = "finalize_blocked_round"
        elif counts["results"] == expected and counts["closed"] == expected:
            next_action = "synthesize_round"
        elif counts["results"] == expected:
            next_action = "close_workers"
        else:
            next_action = "continue_lifecycle"
        status = "round_in_progress"
    return {
        "status": status,
        "current_round": int(latest["round"]),
        "last_finalized_round": max(
            (int(item["round"]) for item in finalized),
            default=0,
        ),
        "next_action": next_action,
        "updated_at": latest.get("updated_at") or state.get("updated_at") or state["created_at"],
    }


def render_ledger_event(round_number: int, event: dict[str, Any]) -> str:
    fields = [
        str(event["recorded_at"]),
        str(event["event_id"]),
        f"round-{round_number:02d}",
        str(event["event"]),
    ]
    for key in ("slot", "status", "agent_id", "summary"):
        value = event.get(key)
        if value not in (None, ""):
            fields.append(f"{key}={value}")
    return " | ".join(fields)


def render_ledger(state: dict[str, Any], rounds: list[dict[str, Any]]) -> str:
    lines = ["# Multi-Agent Analysis Ledger", "", f"Run ID: {state['run_id']}", ""]
    for round_doc in rounds:
        for event in round_doc.get("events", []):
            lines.append(render_ledger_event(int(round_doc["round"]), event))
    return "\n".join(lines) + "\n"


def reconcile_run(run_dir: Path) -> None:
    normalize_legacy_rounds(run_dir)
    state = read_json(run_dir / "state.json")
    if not isinstance(state, dict):
        raise SystemExit("state.json must contain an object")
    rounds = load_all_rounds(run_dir)
    derived = derive_dynamic_state(state, rounds)
    write_json_atomic(run_dir / "state.json", {**state, **derived})
    for round_doc in rounds:
        write_text_atomic(
            run_dir / f"round-{round_doc['round']:02d}.md",
            render_round_markdown(round_doc),
        )
    write_text_atomic(run_dir / "ledger.md", render_ledger(state, rounds))


def load_state(run_dir: Path) -> dict[str, Any]:
    state = read_json(run_dir / "state.json")
    if not isinstance(state, dict):
        raise SystemExit("state.json must contain an object")
    return state


def publish_round_mutation(command: str, run_dir: Path, round_doc: dict[str, Any]) -> None:
    round_number = int(round_doc["round"])
    round_stem = f"round-{round_number:02d}"
    write_json_atomic(run_dir / f"{round_stem}.json", round_doc)
    maybe_fail(command, "after-round-json")

    rounds = load_all_rounds(run_dir)
    for item in rounds:
        write_text_atomic(
            run_dir / f"round-{item['round']:02d}.md",
            render_round_markdown(item),
        )
    maybe_fail(command, "after-round-markdown")

    state = load_state(run_dir)
    write_json_atomic(run_dir / "state.json", {**state, **derive_dynamic_state(state, rounds)})
    maybe_fail(command, "after-state")

    write_text_atomic(run_dir / "ledger.md", render_ledger(state, rounds))
    maybe_fail(command, "after-ledger")


def load_round(run_dir: Path, round_number: int) -> dict[str, Any]:
    round_doc = read_json(run_dir / f"round-{round_number:02d}.json")
    if not isinstance(round_doc, dict):
        raise SystemExit("round JSON must contain an object")
    return round_doc


def find_assignment(round_doc: dict[str, Any], slot: str) -> dict[str, Any]:
    for assignment in round_doc.get("assignments", []):
        if assignment.get("slot") == slot:
            return assignment
    raise SystemExit(f"round-{round_doc.get('round', 0):02d} has no assignment slot {slot!r}")


def validate_record_status(event: str, status: str) -> str:
    value = require_cli_text(status, "--status")
    allowed_by_event = {
        "spawn": SPAWN_STATUSES,
        "result": RESULT_STATUSES,
        "close": CLOSE_STATUSES,
    }
    allowed = allowed_by_event[event]
    if value not in allowed:
        raise SystemExit(
            f"invalid {event} status {value!r}; expected one of {', '.join(sorted(allowed))}"
        )
    return value


def round_counts(round_doc: dict[str, Any]) -> dict[str, int]:
    assignments = round_doc.get("assignments", [])
    return {
        "assignments": len(assignments),
        "spawned": sum(1 for item in assignments if item.get("spawn_status") == "spawned"),
        "planned_dispatches": sum(
            1 for item in assignments if item.get("spawn_status") == "planned"
        ),
        "spawn_failures": sum(1 for item in assignments if item.get("spawn_status") == "failed"),
        "unknown_dispatches": sum(
            1 for item in assignments if item.get("spawn_status") == "unknown"
        ),
        "results": sum(1 for item in assignments if item.get("result_status") == "completed"),
        "result_failures": sum(1 for item in assignments if item.get("result_status") == "failed"),
        "closed": sum(1 for item in assignments if item.get("close_status") == "closed"),
        "close_failures": sum(1 for item in assignments if item.get("close_status") in ABNORMAL_CLOSE_STATUSES),
        "terminal_closes": sum(1 for item in assignments if item.get("close_status") in CLOSE_STATUSES),
        "open_spawned": sum(
            1
            for item in assignments
            if item.get("spawn_status") == "spawned" and item.get("close_status") not in CLOSE_STATUSES
        ),
    }


def expected_agents(round_doc: dict[str, Any]) -> int:
    return int(round_doc.get("expected_agents") or len(round_doc.get("assignments", [])))


def lifecycle_complete(round_doc: dict[str, Any]) -> bool:
    counts = round_counts(round_doc)
    expected = expected_agents(round_doc)
    return counts["results"] == expected and counts["closed"] == expected


def has_lifecycle_failure(round_doc: dict[str, Any]) -> bool:
    counts = round_counts(round_doc)
    return (
        counts["spawn_failures"] > 0
        or counts["unknown_dispatches"] > 0
        or counts["result_failures"] > 0
        or counts["close_failures"] > 0
    )


def require_mutable_round(run_dir: Path, round_doc: dict[str, Any]) -> None:
    state = load_state(run_dir)
    if state.get("status") in TERMINAL_RUN_STATES or state.get("next_action") in TERMINAL_RUN_STATES:
        raise SystemExit(f"run is terminal with status={state.get('status')!r}")
    if round_doc.get("status") in TERMINAL_ROUND_STATES:
        raise SystemExit(
            f"round-{int(round_doc.get('round', 0)):02d} is already {round_doc.get('status')}"
        )


def validate_round_decision(
    round_number: int,
    decision: str,
    round_cap: int,
    protocol: str,
) -> None:
    if decision == "continue_round_2" and round_number != 1:
        raise SystemExit("continue_round_2 is only valid when finalizing round 1")
    if decision == "ask_user" and round_number < 2:
        raise SystemExit("ask_user is only valid when finalizing round 2 or later")
    if protocol == LEGACY_PROTOCOL and decision == "ask_user" and round_number >= round_cap:
        raise SystemExit(f"round {round_number} is the round cap; decision must be stop")


def open_spawned_slots(round_doc: dict[str, Any]) -> list[str]:
    slots: list[str] = []
    for item in round_doc.get("assignments", []):
        if item.get("spawn_status") == "spawned" and item.get("close_status") not in CLOSE_STATUSES:
            slots.append(str(item.get("slot")))
    return slots


def list_has_content(value: Any) -> bool:
    return isinstance(value, list) and any(non_empty_text(item) for item in value)


def validate_object_list(value: Any, key: str, fields: list[str]) -> list[dict[str, str]]:
    if not isinstance(value, list):
        raise SystemExit(f"synthesis field {key!r} must be an array")
    output: list[dict[str, str]] = []
    for index, item in enumerate(value, start=1):
        if not isinstance(item, dict):
            raise SystemExit(f"synthesis field {key!r} item {index} must be an object")
        row: dict[str, str] = {}
        for field in fields:
            row[field] = require_text(item.get(field), f"{key}.{field}", index)
        output.append(row)
    return output


def validate_objective_alignment(value: Any) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise SystemExit("objective_alignment must be an object")
    if set(value) != OBJECTIVE_ALIGNMENT_FIELDS:
        raise SystemExit("objective_alignment must contain exactly status, rationale, unmet_requirements")

    status = value.get("status")
    if not isinstance(status, str) or status not in OBJECTIVE_ALIGNMENT_STATUSES:
        raise SystemExit("objective_alignment status is invalid")

    rationale = value.get("rationale")
    if not isinstance(rationale, str) or not rationale.strip():
        raise SystemExit("objective_alignment rationale must be a non-empty string")

    unmet_requirements = value.get("unmet_requirements")
    if not isinstance(unmet_requirements, list):
        raise SystemExit("objective_alignment unmet_requirements must be an array")
    for index, item in enumerate(unmet_requirements, start=1):
        if not isinstance(item, str) or not item.strip():
            raise SystemExit(
                f"objective_alignment unmet_requirements item {index} must be a non-empty string"
            )

    if status == "aligned" and unmet_requirements:
        raise SystemExit("objective_alignment aligned status requires no unmet_requirements")
    if status == "needs_revision" and not unmet_requirements:
        raise SystemExit("objective_alignment needs_revision status requires unmet_requirements")

    return {
        "status": status,
        "rationale": rationale,
        "unmet_requirements": unmet_requirements,
    }


def validate_adaptive_targets(
    value: Any,
    critical_disagreements: Any,
) -> list[dict[str, Any]]:
    if not isinstance(value, list):
        raise SystemExit("synthesis field 'cross_review_targets' must be an array")
    disagreements = critical_disagreements if isinstance(critical_disagreements, list) else []
    targets: list[dict[str, Any]] = []
    for index, item in enumerate(value, start=1):
        if not isinstance(item, dict):
            raise SystemExit(f"synthesis field 'cross_review_targets' item {index} must be an object")
        target: dict[str, Any] = {}
        for field in ADAPTIVE_CROSS_REVIEW_TARGET_FIELDS:
            if field == "conflict_ref":
                if field not in item:
                    raise SystemExit(
                        f"synthesis field 'cross_review_targets' item {index} "
                        "must include conflict_ref"
                    )
                target[field] = item.get(field)
            else:
                target[field] = require_text(
                    item.get(field),
                    f"cross_review_targets.{field}",
                    index,
                )
        if target["disposition"] not in CROSS_REVIEW_TARGET_DISPOSITIONS:
            raise SystemExit("cross_review_targets disposition is invalid")
        policy = target["review_policy"]
        conflict_ref = target["conflict_ref"]
        if policy == "single":
            if conflict_ref is not None:
                raise SystemExit("single review_policy requires conflict_ref null")
        elif policy == "dual":
            match = re.fullmatch(r"critical_disagreements\[(\d+)\]", str(conflict_ref or ""))
            if match is None:
                raise SystemExit(
                    "dual review_policy requires conflict_ref critical_disagreements[N]"
                )
            conflict_index = int(match.group(1))
            if conflict_index >= len(disagreements):
                raise SystemExit("dual review_policy conflict_ref does not exist in this synthesis")
        else:
            raise SystemExit("cross_review_targets review_policy must be 'single' or 'dual'")
        targets.append(target)
    return targets


def target_ids_from_targets(targets: Any) -> set[str]:
    if not isinstance(targets, list):
        return set()
    return {str(item.get("target_id")) for item in targets if isinstance(item, dict) and item.get("target_id")}


def pending_target_ids(targets: Any) -> set[str]:
    if not isinstance(targets, list):
        return set()
    ids: set[str] = set()
    for item in targets:
        if not isinstance(item, dict):
            continue
        if item.get("disposition") == "pending":
            ids.add(str(item.get("target_id")))
    return ids


def target_ids_with_disposition(targets: Any, disposition: str) -> set[str]:
    if not isinstance(targets, list):
        return set()
    ids: set[str] = set()
    for item in targets:
        if not isinstance(item, dict):
            continue
        if item.get("disposition") == disposition and non_empty_text(item.get("target_id")):
            ids.add(str(item.get("target_id")))
    return ids


def require_synthesis_ready(
    round_doc: dict[str, Any], *, require_objective_alignment: bool = True
) -> None:
    synthesis = round_doc.get("synthesis")
    if not isinstance(synthesis, dict):
        raise SystemExit("cannot finalize complete round before synthesis is populated")

    missing: list[str] = []
    if not list_has_content(synthesis.get("convergence")):
        missing.append("convergence")
    if not list_has_content(synthesis.get("action_list")):
        missing.append("action_list")
    if not non_empty_text(synthesis.get("expected_value_of_another_round")):
        missing.append("expected_value_of_another_round")
    if require_objective_alignment and "objective_alignment" not in synthesis:
        missing.append("objective_alignment")

    if missing:
        raise SystemExit(
            "cannot finalize complete round before synthesis is populated: "
            + ", ".join(missing)
        )

    if "objective_alignment" in synthesis:
        validate_objective_alignment(synthesis["objective_alignment"])


def synthesis_is_ready(
    round_doc: dict[str, Any], *, require_objective_alignment: bool = True
) -> bool:
    try:
        require_synthesis_ready(
            round_doc,
            require_objective_alignment=require_objective_alignment,
        )
    except SystemExit:
        return False
    return True


def validate_synthesis_payload(raw: Any, *, adaptive: bool = False) -> dict[str, Any]:
    if not isinstance(raw, dict):
        raise SystemExit("synthesis JSON must contain an object")

    allowed = (
        set(SYNTHESIS_LIST_FIELDS)
        | set(SYNTHESIS_TEXT_FIELDS)
        | {"cross_review_targets", "cross_review_outcomes", "objective_alignment"}
    )
    unknown = set(raw) - allowed
    if unknown:
        raise SystemExit(f"synthesis JSON has unknown fields: {', '.join(sorted(unknown))}")
    validated: dict[str, Any] = {}
    if "objective_alignment" in raw:
        validated["objective_alignment"] = validate_objective_alignment(
            raw["objective_alignment"]
        )
    for key in SYNTHESIS_LIST_FIELDS:
        if key not in raw:
            continue
        value = raw[key]
        if not isinstance(value, list):
            raise SystemExit(f"synthesis field {key!r} must be an array")
        for index, item in enumerate(value, start=1):
            if not isinstance(item, str):
                raise SystemExit(f"synthesis field {key!r} item {index} must be a string")
        validated[key] = value

    for key in SYNTHESIS_TEXT_FIELDS:
        if key not in raw:
            continue
        value = raw[key]
        if not isinstance(value, str):
            raise SystemExit(f"synthesis field {key!r} must be a string")
        if key == "cross_review_gate_status" and value not in CROSS_REVIEW_GATE_STATUSES:
            raise SystemExit(
                "synthesis field 'cross_review_gate_status' must be one of "
                + ", ".join(sorted(CROSS_REVIEW_GATE_STATUSES))
            )
        if key == "next_round_decision" and value not in SYNTHESIS_DECISIONS:
            raise SystemExit(
                "synthesis field 'next_round_decision' must be one of "
                + ", ".join(sorted(SYNTHESIS_DECISIONS))
            )
        validated[key] = value

    for key in ["cross_review_targets", "cross_review_outcomes"]:
        if key not in raw:
            continue
        value = raw[key]
        if key == "cross_review_targets":
            if adaptive:
                targets = validate_adaptive_targets(
                    value,
                    raw.get("critical_disagreements", []),
                )
            else:
                targets = validate_object_list(value, key, CROSS_REVIEW_TARGET_FIELDS)
                for item in targets:
                    if item["disposition"] not in CROSS_REVIEW_TARGET_DISPOSITIONS:
                        raise SystemExit("cross_review_targets disposition is invalid")
            validated[key] = targets
        else:
            outcomes = validate_object_list(value, key, CROSS_REVIEW_OUTCOME_FIELDS)
            for item in outcomes:
                if item["status"] not in CROSS_REVIEW_OUTCOME_STATUSES:
                    raise SystemExit("cross_review_outcomes status is invalid")
            validated[key] = outcomes

    return validated


def previous_round_pending_targets(run_dir: Path, round_number: int) -> set[str]:
    if round_number != 2:
        return set()
    previous = load_round(run_dir, 1)
    synthesis = previous.get("synthesis") or {}
    if synthesis.get("cross_review_gate_status") != "needs_cross_review":
        return set()
    return pending_target_ids(synthesis.get("cross_review_targets"))


def validate_cross_review_round_assignments(
    assignments: list[dict[str, Any]], required_target_ids: set[str]
) -> None:
    if not required_target_ids:
        return
    actual_slots = [str(item.get("slot")) for item in assignments]
    expected_slots = [f"C{index}" for index in range(1, EXPECTED_AGENTS_PER_ROUND + 1)]
    if actual_slots != expected_slots:
        raise SystemExit(
            "targeted cross-review rounds must use exactly C1, C2, C3, C4, C5, C6 in order"
        )
    assigned: set[str] = set()
    for index, item in enumerate(assignments, start=1):
        target_id = require_text(item.get("target_id"), "target_id", index)
        if target_id not in required_target_ids:
            raise SystemExit(f"assignment {index} references unknown cross-review target_id {target_id!r}")
        assigned.add(target_id)
    missing = required_target_ids - assigned
    if missing:
        raise SystemExit("round 2 assignments do not cover cross-review target ids: " + ", ".join(sorted(missing)))


def validate_adaptive_followup_assignments(
    run_dir: Path,
    assignments: list[dict[str, Any]],
    batch: list[tuple[str, int]],
) -> tuple[list[dict[str, Any]], list[str]]:
    expected_target_ids = [
        target_id
        for target_id, seats in batch
        for _ in range(seats)
    ]
    actual_slots = [str(item.get("slot")) for item in assignments]
    expected_slots = [f"C{index}" for index in range(1, len(expected_target_ids) + 1)]
    if actual_slots != expected_slots:
        raise SystemExit(
            "adaptive follow-up slots must be consecutive from C1 through "
            f"C{len(expected_slots)}"
        )
    actual_target_ids = [
        require_text(item.get("target_id"), "target_id", index)
        for index, item in enumerate(assignments, start=1)
    ]
    if actual_target_ids != expected_target_ids:
        raise SystemExit(
            "adaptive follow-up assignments must exactly match the expected complete target bundles"
        )

    enriched: list[dict[str, Any]] = []
    for item, target_id in zip(assignments, actual_target_ids):
        target = canonical_target(run_dir, target_id)
        canonical_fields = {
            key: target.get(key)
            for key in ("source_slot", "claim", "review_policy", "conflict_ref")
        }
        for key, value in canonical_fields.items():
            if key in item and item.get(key) != value:
                raise SystemExit(
                    f"assignment {item['slot']} {key} conflicts with canonical target {target_id!r}"
                )
        enriched.append({**item, **canonical_fields})
    return enriched, [target_id for target_id, _ in batch]


def adaptive_prepare_replay_plan(
    round_doc: dict[str, Any],
    assignments: list[dict[str, Any]],
) -> tuple[list[dict[str, Any]], list[str], list[str]]:
    stored_assignments = round_doc.get("assignments")
    incoming = round_doc.get("incoming_backlog_ids")
    active = round_doc.get("active_target_ids")
    if not isinstance(stored_assignments, list):
        raise SystemExit("adaptive replay round assignments must be an array")
    if not isinstance(incoming, list) or not all(isinstance(item, str) for item in incoming):
        raise SystemExit("adaptive replay incoming_backlog_ids must be a string array")
    if not isinstance(active, list) or not all(isinstance(item, str) for item in active):
        raise SystemExit("adaptive replay active_target_ids must be a string array")
    if len(assignments) != len(stored_assignments):
        raise SystemExit("conflicting adaptive prepare replay assignment count")

    stored_slots = [str(item.get("slot")) for item in stored_assignments]
    expected_slots = [f"C{index}" for index in range(1, len(stored_assignments) + 1)]
    if stored_slots != expected_slots:
        raise SystemExit("stored adaptive follow-up slots are not consecutive")
    stored_target_ids = [str(item.get("target_id") or "") for item in stored_assignments]
    stored_active = list(dict.fromkeys(stored_target_ids))
    if not all(stored_target_ids) or stored_active != active:
        raise SystemExit("stored adaptive assignments conflict with active_target_ids")
    if any(target_id not in incoming for target_id in active):
        raise SystemExit("stored active_target_ids are not present in incoming_backlog_ids")

    canonical_fields = ("source_slot", "claim", "review_policy", "conflict_ref")
    enriched: list[dict[str, Any]] = []
    for requested, stored in zip(assignments, stored_assignments):
        for key in canonical_fields:
            if key in requested and requested.get(key) != stored.get(key):
                raise SystemExit(
                    f"assignment {requested['slot']} {key} conflicts with stored adaptive plan"
                )
        enriched.append(
            {
                **requested,
                **{key: stored.get(key) for key in canonical_fields},
            }
        )
    return enriched, list(incoming), list(active)


def validate_adaptive_target_origins(
    run_dir: Path,
    round_doc: dict[str, Any],
    introduced_targets: list[dict[str, Any]],
    canonical_targets: list[dict[str, Any]],
) -> None:
    if int(round_doc["round"]) >= 2 and len(canonical_targets) > 1:
        raise SystemExit("adaptive follow-up synthesis may introduce at most one new canonical target")

    prior_ids = {
        str(item.get("target_id"))
        for stored_round in load_all_rounds(run_dir)
        for item in (stored_round.get("synthesis") or {}).get("cross_review_targets", [])
        if item.get("target_id")
    }
    new_ids: set[str] = set()
    for target in introduced_targets:
        target_id = str(target["target_id"])
        if target_id in prior_ids or target_id in new_ids:
            raise SystemExit(f"duplicate canonical target {target_id!r}")
        new_ids.add(target_id)
        source_slot = str(target["source_slot"])
        assignment = find_assignment(round_doc, source_slot)
        if assignment.get("spawn_status") != "spawned":
            raise SystemExit(
                f"target {target_id!r} source_slot {source_slot!r} was not spawned"
            )
        if assignment.get("result_status") != "completed":
            raise SystemExit(
                f"target {target_id!r} source_slot {source_slot!r} has no completed result"
            )


def adaptive_correction_target_additions(
    synthesis: dict[str, Any],
    payload: dict[str, Any],
) -> list[dict[str, Any]]:
    if "cross_review_targets" not in payload:
        return []
    proposed = payload["cross_review_targets"]
    existing = synthesis.get("cross_review_targets", [])
    if not isinstance(existing, list):
        raise SystemExit("canonical cross_review_targets must be an array")
    if proposed[: len(existing)] != existing:
        raise SystemExit(
            "adaptive synthesis correction cannot remove, reorder, replace, or mutate "
            "canonical cross_review_targets"
        )
    return proposed[len(existing) :]


def validate_adaptive_outcomes(round_doc: dict[str, Any], outcomes: Any) -> None:
    active_target_ids = [str(item) for item in round_doc.get("active_target_ids", [])]
    if not active_target_ids:
        if outcomes:
            raise SystemExit(
                "adaptive synthesis cannot record target outcomes without active target ids"
            )
        return
    if not isinstance(outcomes, list):
        raise SystemExit("adaptive follow-up synthesis must include cross_review_outcomes")
    outcome_ids = [str(item.get("target_id")) for item in outcomes]
    if len(outcome_ids) != len(set(outcome_ids)):
        raise SystemExit("adaptive follow-up outcomes must contain each active target exactly once")
    if set(outcome_ids) != set(active_target_ids) or len(outcome_ids) != len(active_target_ids):
        raise SystemExit("adaptive follow-up outcomes must match exactly the active target ids")


def reject_exhausted_unresolved_outcomes(
    run_dir: Path,
    outcomes: list[dict[str, Any]],
) -> None:
    for outcome in outcomes:
        if outcome.get("status") != "unresolved":
            continue
        target_id = str(outcome["target_id"])
        used = completed_review_count(run_dir, target_id)
        textual_limit = initial_review_quota(run_dir, target_id) + 1
        if used >= textual_limit:
            raise SystemExit(
                f"target {target_id!r} exhausted textual review; outcome must be "
                "accepted, modified, rejected, or external-verification"
            )


def rounds_with_candidate(
    run_dir: Path,
    candidate: dict[str, Any],
) -> list[dict[str, Any]]:
    round_number = int(candidate["round"])
    return [
        candidate if int(item["round"]) == round_number else item
        for item in load_all_rounds(run_dir)
    ]


ASSIGNMENT_LIFECYCLE_FIELDS = {
    "agent_id",
    "spawn_status",
    "spawn_planned_at",
    "spawn_recorded_at",
    "result_status",
    "result_summary",
    "result_recorded_at",
    "close_status",
    "close_recorded_at",
}


def planned_assignments(
    assignments: list[dict[str, Any]], state: dict[str, Any]
) -> list[dict[str, Any]]:
    planned_items: list[dict[str, Any]] = []
    tooling = state.get("tooling", {})
    for item in assignments:
        planned = {
            key: value
            for key, value in item.items()
            if key not in ASSIGNMENT_LIFECYCLE_FIELDS
        }
        planned["agent_id"] = None
        planned.setdefault("spawn_tool", tooling.get("spawn"))
        planned.setdefault("wait_tool", tooling.get("wait"))
        planned.setdefault("close_tool", tooling.get("close"))
        planned["spawn_status"] = "pending"
        planned["result_status"] = "pending"
        planned["close_status"] = "pending"
        planned["result_summary"] = ""
        planned_items.append(planned)
    return planned_items


def assignment_plan(item: dict[str, Any]) -> dict[str, Any]:
    return {
        key: value
        for key, value in item.items()
        if key not in ASSIGNMENT_LIFECYCLE_FIELDS
    }


def round_plan_digest(assignments: list[dict[str, Any]]) -> str:
    return canonical_json_digest([assignment_plan(item) for item in assignments])


def preparation_summary(count: int, protocol: str) -> str:
    if protocol == LEGACY_PROTOCOL:
        return "prepared exactly six assignments"
    return f"prepared {count} assignment{'s' if count != 1 else ''}"


def require_prepare_replay(
    round_doc: dict[str, Any],
    state: dict[str, Any],
    round_number: int,
    assignments: list[dict[str, Any]],
    incoming_backlog_ids: list[str],
    active_target_ids: list[str],
    protocol: str,
) -> None:
    expected_header = {
        "version": VERSION,
        "run_id": state.get("run_id"),
        "mode": state.get("mode"),
        "round": round_number,
        "expected_agents": len(assignments),
    }
    if any(round_doc.get(key) != value for key, value in expected_header.items()):
        raise SystemExit(f"conflicting replay for round-{round_number:02d} preparation")
    existing_plans = [assignment_plan(item) for item in round_doc.get("assignments", [])]
    requested_plans = [assignment_plan(item) for item in assignments]
    if existing_plans != requested_plans:
        raise SystemExit(f"conflicting replay for round-{round_number:02d} preparation")
    if round_doc.get("incoming_backlog_ids", []) != incoming_backlog_ids:
        raise SystemExit(f"conflicting replay for round-{round_number:02d} preparation")
    if round_doc.get("active_target_ids", []) != active_target_ids:
        raise SystemExit(f"conflicting replay for round-{round_number:02d} preparation")
    replay_summary = preparation_summary(len(assignments), protocol)
    existing_prepare = find_event(round_doc, event_id(round_number, "round", "prepare"))
    if (
        existing_prepare is not None
        and existing_prepare.get("summary") == "prepared exactly six assignments"
    ):
        replay_summary = "prepared exactly six assignments"
    requested_event = event_content(
        round_number,
        "round",
        "prepare",
        status="planned",
        summary=replay_summary,
        plan_digest=round_plan_digest(assignments),
    )
    require_event_replay(round_doc, requested_event)


def command_prepare_round(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    with run_lock(run_dir):
        reconcile_run(run_dir)
        state = load_state(run_dir)
        round_number = args.round
        protocol = protocol_version(state)
        round_cap = int(state.get("round_cap", ROUND_CAP))
        if round_number < 1:
            raise SystemExit("round must be at least 1")
        if protocol == LEGACY_PROTOCOL and round_number > round_cap:
            raise SystemExit(f"round {round_number} exceeds round cap {round_cap}")
        if round_number >= USER_APPROVAL_FROM_ROUND and not args.user_approved:
            raise SystemExit(f"round {round_number} requires user approval")

        mode = str(state.get("mode"))
        review_portfolio = review_portfolio_version(state) if mode == "review" else None
        assignments = validate_assignments(
            read_json(Path(args.assignments)),
            mode,
            round_number,
            protocol,
            str(state.get("target_overlay") or ""),
            review_round_one_dimensions(state) if mode == "review" else None,
            review_portfolio,
        )
        round_stem = f"round-{round_number:02d}"
        round_json = run_dir / f"{round_stem}.json"
        incoming_backlog_ids: list[str] = []
        active_target_ids: list[str] = []
        if round_json.exists():
            stored_round = load_round(run_dir, round_number)
            if protocol == ADAPTIVE_PROTOCOL and round_number >= 2:
                assignments, incoming_backlog_ids, active_target_ids = (
                    adaptive_prepare_replay_plan(stored_round, assignments)
                )
            planned = planned_assignments(assignments, state)
            require_prepare_replay(
                stored_round,
                state,
                round_number,
                planned,
                incoming_backlog_ids,
                active_target_ids,
                protocol,
            )
            print(round_json)
            return 0

        if protocol == ADAPTIVE_PROTOCOL and round_number >= 2:
            incoming_backlog_ids = pending_backlog(run_dir)
            batch = expected_followup_batch(run_dir)
            if not batch:
                raise SystemExit("adaptive follow-up round requires a non-empty pending backlog")
            assignments, active_target_ids = validate_adaptive_followup_assignments(
                run_dir,
                assignments,
                batch,
            )
        planned = planned_assignments(assignments, state)

        if state.get("status") in TERMINAL_RUN_STATES or state.get("next_action") in TERMINAL_RUN_STATES:
            raise SystemExit(
                f"cannot prepare another round because run status is {state.get('status')!r}"
            )

        last_finalized = int(state.get("last_finalized_round", 0))
        if round_number == 1:
            if last_finalized != 0:
                raise SystemExit("round 1 cannot be prepared after a finalized round")
        elif round_number != last_finalized + 1:
            raise SystemExit(f"round {round_number} requires round {round_number - 1} finalized first")

        if protocol == LEGACY_PROTOCOL:
            required_target_ids = previous_round_pending_targets(run_dir, round_number)
            validate_cross_review_round_assignments(assignments, required_target_ids)
        created_at = now_iso()
        prepare_event = event_content(
            round_number,
            "round",
            "prepare",
            status="planned",
            summary=preparation_summary(len(planned), protocol),
            plan_digest=round_plan_digest(planned),
        )
        round_doc = {
            "version": VERSION,
            "run_id": state.get("run_id"),
            "mode": state.get("mode"),
            "round": round_number,
            "status": "planned",
            "created_at": created_at,
            "updated_at": created_at,
            "expected_agents": len(planned),
            "assignments": planned,
            "synthesis": {
                "convergence": [],
                "disagreement": [],
                "critical_disagreements": [],
                "cannot_verify": [],
                "high_impact_low_evidence": [],
                "action_list": [],
                "cross_review_gate_status": "",
                "cross_review_targets": [],
                "cross_review_outcomes": [],
                "expected_value_of_another_round": "",
                "next_round_decision": "",
                "stop_reason": "",
                "next_round_question": "",
            },
            "events": [{**prepare_event, "recorded_at": created_at}],
        }
        if protocol == ADAPTIVE_PROTOCOL and round_number >= 2:
            round_doc["incoming_backlog_ids"] = incoming_backlog_ids
            round_doc["active_target_ids"] = active_target_ids
        publish_round_mutation("prepare-round", run_dir, round_doc)

        print(round_json)
    return 0


def command_plan_dispatch(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    with run_lock(run_dir):
        reconcile_run(run_dir)
        round_doc = load_round(run_dir, args.round)
        assignment = find_assignment(round_doc, args.slot)
        requested_event = event_content(
            args.round,
            args.slot,
            "plan-dispatch",
            status="planned",
        )
        if find_event(round_doc, str(requested_event["event_id"])) is not None:
            require_event_replay(round_doc, requested_event)
            print(run_dir / f"round-{args.round:02d}.json")
            return 0
        require_mutable_round(run_dir, round_doc)
        current_status = assignment.get("spawn_status")
        if current_status not in (None, "", "pending"):
            raise SystemExit(
                f"{args.slot} dispatch cannot be planned after spawn_status={current_status!r}"
            )

        timestamp = now_iso()
        assignment["spawn_status"] = "planned"
        assignment["spawn_planned_at"] = timestamp
        append_canonical_event(round_doc, requested_event, timestamp)
        round_doc["updated_at"] = timestamp
        publish_round_mutation("plan-dispatch", run_dir, round_doc)
        print(run_dir / f"round-{args.round:02d}.json")
    return 0


def command_record(args: argparse.Namespace, event: str) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    with run_lock(run_dir):
        reconcile_run(run_dir)
        state = load_state(run_dir)
        adaptive = protocol_version(state) == ADAPTIVE_PROTOCOL
        round_doc = load_round(run_dir, args.round)
        assignment = find_assignment(round_doc, args.slot)
        status = validate_record_status(event, args.status)
        summary = args.summary or ""
        requested_agent_id = args.agent_id.strip()

        if event == "spawn":
            agent_id = requested_agent_id
            status_field = "spawn_status"
            if status == "planned":
                raise SystemExit("use plan-dispatch to record planned dispatch intent")
            if status == "spawned" and not agent_id:
                raise SystemExit(f"{args.slot} must record --agent-id when spawn status is 'spawned'")
            if status in {"failed", "unknown"} and agent_id:
                raise SystemExit(
                    f"{args.slot} must not record --agent-id when spawn status is {status!r}"
                )
        elif event in {"result", "close"}:
            agent_id = requested_agent_id or str(assignment.get("agent_id") or "")
            status_field = f"{event}_status"
        else:
            raise SystemExit(f"unknown record event: {event}")

        requested_event = event_content(
            args.round,
            args.slot,
            event,
            status=status,
            agent_id=agent_id,
            summary=summary,
        )
        committed_statuses = (None, "", "pending", "planned") if event == "spawn" else (None, "", "pending")
        if assignment.get(status_field) not in committed_statuses:
            require_event_replay(round_doc, requested_event)
            print(run_dir / f"round-{args.round:02d}.json")
            return 0

        require_mutable_round(run_dir, round_doc)
        if event == "spawn" and adaptive and assignment.get("spawn_status") != "planned":
            raise SystemExit(
                f"{args.slot} adaptive dispatch must be planned before recording spawn status"
            )
        if event == "spawn" and status == "spawned":
            require_unused_spawned_agent_id(run_dir, args.round, args.slot, agent_id)
        if event in {"result", "close"}:
            if assignment.get("spawn_status") != "spawned":
                action = "a result" if event == "result" else "close"
                raise SystemExit(
                    f"{args.slot} cannot record {action} unless spawn_status is 'spawned'"
                )
            if requested_agent_id and requested_agent_id != assignment.get("agent_id"):
                raise SystemExit(
                    f"{args.slot} agent_id conflicts with the recorded spawn agent_id"
                )
        if event == "close" and assignment.get("result_status") in (None, "", "pending") and status == "closed":
            raise SystemExit(
                f"{args.slot} cannot record successful close before result is recorded; "
                "use status failed or cancelled for abnormal close"
            )

        timestamp = now_iso()
        if event == "spawn":
            if agent_id:
                assignment["agent_id"] = agent_id
            assignment["spawn_status"] = status
            assignment["spawn_recorded_at"] = timestamp
        elif event == "result":
            assignment["result_status"] = status
            assignment["result_summary"] = summary
            assignment["result_recorded_at"] = timestamp
        else:
            assignment["close_status"] = status
            assignment["close_recorded_at"] = timestamp

        append_canonical_event(round_doc, requested_event, timestamp)
        round_doc["updated_at"] = timestamp
        publish_round_mutation(f"record-{event}", run_dir, round_doc)

        print(run_dir / f"round-{args.round:02d}.json")
    return 0


def command_record_synthesis(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    raw_payload = read_json(Path(args.synthesis))

    with run_lock(run_dir):
        reconcile_run(run_dir)
        state = load_state(run_dir)
        adaptive = protocol_version(state) == ADAPTIVE_PROTOCOL
        payload = validate_synthesis_payload(raw_payload, adaptive=adaptive)
        digest = canonical_json_digest(payload)
        requested_event = event_content(
            args.round,
            "round",
            "synthesis",
            summary=f"fields={','.join(sorted(payload))}",
            content_digest=digest,
        )
        round_doc = load_round(run_dir, args.round)
        synthesis_events = [
            item for item in round_doc.get("events", []) if item.get("event") == "synthesis"
        ]
        has_canonical_correction = any(
            item.get("migrated_snapshot") is not True for item in synthesis_events
        )
        existing_event = find_event(round_doc, str(requested_event["event_id"]))
        if existing_event is not None:
            if existing_event.get("migrated_snapshot") is True and has_canonical_correction:
                raise SystemExit(
                    "canonical synthesis correction already exists; replay its exact event payload"
                )
            require_event_replay(round_doc, requested_event)
            synthesis = round_doc.get("synthesis")
            if not isinstance(synthesis, dict) or any(
                synthesis.get(key) != value for key, value in payload.items()
            ):
                raise SystemExit("conflicting replay for synthesis payload")
            print(run_dir / f"round-{args.round:02d}.json")
            return 0

        require_mutable_round(run_dir, round_doc)
        if not lifecycle_complete(round_doc):
            counts = round_counts(round_doc)
            raise SystemExit(
                "cannot record synthesis before lifecycle completion "
                f"(results={counts['results']}, closed={counts['closed']})"
            )

        synthesis = round_doc.get("synthesis")
        if not isinstance(synthesis, dict):
            raise SystemExit("round synthesis must be an object")
        merged_synthesis = {**synthesis, **payload}
        if "objective_alignment" not in merged_synthesis:
            raise SystemExit(
                "new mutable synthesis must include objective_alignment"
            )
        merged_synthesis["objective_alignment"] = validate_objective_alignment(
            merged_synthesis["objective_alignment"]
        )
        if adaptive:
            introduced_targets = adaptive_correction_target_additions(synthesis, payload)
            validate_adaptive_target_origins(
                run_dir,
                round_doc,
                introduced_targets,
                merged_synthesis.get("cross_review_targets", []),
            )
            validate_adaptive_outcomes(
                round_doc,
                merged_synthesis.get("cross_review_outcomes"),
            )
            if round_doc.get("active_target_ids"):
                reject_exhausted_unresolved_outcomes(
                    run_dir,
                    merged_synthesis["cross_review_outcomes"],
                )
            candidate = {**round_doc, "synthesis": merged_synthesis}
            candidate_rounds = rounds_with_candidate(run_dir, candidate)
            backlog = pending_backlog_from_rounds(candidate_rounds)
            gate_status, decision = adaptive_gate_and_decision(
                args.round,
                backlog,
                has_external_verification(candidate_rounds),
            )
            caller_assertions = {
                "cross_review_gate_status": gate_status,
                "next_round_decision": decision,
            }
            for key, derived_value in caller_assertions.items():
                if key in payload and payload[key] != derived_value:
                    raise SystemExit(
                        f"adaptive synthesis derives {key} as {derived_value!r}; "
                        f"caller asserted {payload[key]!r}"
                    )
            merged_synthesis["cross_review_gate_status"] = gate_status
            merged_synthesis["next_round_decision"] = decision
        round_doc["synthesis"] = merged_synthesis
        timestamp = now_iso()
        round_doc["synthesis_recorded_at"] = timestamp
        round_doc["updated_at"] = timestamp
        append_canonical_event(round_doc, requested_event, timestamp)
        publish_round_mutation("record-synthesis", run_dir, round_doc)

        print(run_dir / f"round-{args.round:02d}.json")
    return 0


def validate_cross_review_finalization(
    run_dir: Path,
    round_doc: dict[str, Any],
    decision: str,
) -> None:
    synthesis = round_doc.get("synthesis") or {}
    gate_status = str(synthesis.get("cross_review_gate_status") or "")
    if gate_status not in CROSS_REVIEW_GATE_STATUSES:
        raise SystemExit("cross_review_gate_status is invalid")
    current_pending = pending_target_ids(synthesis.get("cross_review_targets"))
    if current_pending:
        if gate_status != "needs_cross_review":
            raise SystemExit(
                "cross_review_gate_status must be needs_cross_review when pending cross-review targets exist"
            )
        if decision != "continue_round_2":
            raise SystemExit(
                "pending cross-review targets require continue_round_2 decision"
            )
    elif gate_status == "needs_cross_review":
        if decision != "continue_round_2":
            raise SystemExit("cross_review_gate_status needs_cross_review requires continue_round_2")
        raise SystemExit(
            "cross_review_gate_status needs_cross_review requires at least one pending target"
        )

    if decision != "stop":
        return

    current_externalized = target_ids_with_disposition(
        synthesis.get("cross_review_targets"),
        "external_verification",
    )
    if current_externalized and gate_status != "external_verification":
        raise SystemExit(
            "external_verification cross-review targets require cross_review_gate_status "
            "external_verification"
        )

    outcomes = synthesis.get("cross_review_outcomes") or []
    if isinstance(outcomes, list):
        unresolved = [
            str(item.get("target_id"))
            for item in outcomes
            if isinstance(item, dict) and item.get("status") == "unresolved"
        ]
        if unresolved:
            raise SystemExit(
                "cannot stop with unresolved cross-review outcomes: " + ", ".join(unresolved)
            )
        external = [
            str(item.get("target_id"))
            for item in outcomes
            if isinstance(item, dict) and item.get("status") == "external-verification"
        ]
        if external and gate_status != "external_verification":
            raise SystemExit("external-verification outcomes require cross_review_gate_status external_verification")

    required_target_ids = previous_round_pending_targets(run_dir, int(round_doc.get("round", 0)))
    if not required_target_ids:
        return
    if not isinstance(outcomes, list):
        raise SystemExit("cannot stop without cross-review outcomes for prior pending target ids")
    outcome_target_ids = {
        str(item.get("target_id"))
        for item in outcomes
        if isinstance(item, dict) and non_empty_text(item.get("target_id"))
    }
    extra = outcome_target_ids - required_target_ids
    if extra:
        raise SystemExit(
            "cannot stop with cross-review outcomes for unknown prior pending target ids: "
            + ", ".join(sorted(extra))
        )
    missing = required_target_ids - outcome_target_ids
    if missing:
        raise SystemExit(
            "cannot stop without outcomes for prior pending target ids: "
            + ", ".join(sorted(missing))
        )


def validate_objective_alignment_finalization(round_doc: dict[str, Any]) -> None:
    synthesis = round_doc.get("synthesis") or {}
    validate_objective_alignment(synthesis.get("objective_alignment"))


def command_finalize_round(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    round_status = "blocked" if args.blocked else "finalized"
    requested_event = event_content(
        args.round,
        "round",
        "finalize",
        status=round_status,
        summary=args.summary,
        decision=args.decision,
        blocked=args.blocked,
    )

    with run_lock(run_dir):
        reconcile_run(run_dir)
        round_doc = load_round(run_dir, args.round)
        state = load_state(run_dir)
        protocol = protocol_version(state)
        validate_round_decision(
            args.round,
            args.decision,
            int(state.get("round_cap", ROUND_CAP)),
            protocol,
        )

        if find_event(round_doc, str(requested_event["event_id"])) is not None:
            require_event_replay(round_doc, requested_event)
            if round_doc.get("status") != round_status:
                raise SystemExit("conflicting replay for finalized round status")
            print(run_dir / "state.json")
            return 0

        require_mutable_round(run_dir, round_doc)
        counts = round_counts(round_doc)
        if counts["planned_dispatches"]:
            raise SystemExit(
                "cannot finalize while dispatch intent remains planned; "
                "record spawned, failed, or unknown first"
            )
        round_complete = lifecycle_complete(round_doc)
        if not round_complete and not args.blocked:
            raise SystemExit(
                "cannot finalize incomplete round without --blocked "
                f"(results={counts['results']}, closed={counts['closed']})"
            )
        if round_complete and args.blocked:
            raise SystemExit("cannot finalize a complete round as blocked")
        if args.blocked and args.decision != "stop":
            raise SystemExit("blocked rounds must finalize with --decision stop")
        if args.blocked:
            if not has_lifecycle_failure(round_doc):
                raise SystemExit("blocked rounds require a recorded lifecycle failure")
            open_slots = open_spawned_slots(round_doc)
            if open_slots:
                raise SystemExit(
                    "cannot finalize blocked round while spawned workers are still open: "
                    + ", ".join(open_slots)
                )
        else:
            require_synthesis_ready(round_doc)
            validate_objective_alignment_finalization(round_doc)
            if protocol == ADAPTIVE_PROTOCOL:
                derived_decision = str(
                    (round_doc.get("synthesis") or {}).get("next_round_decision") or ""
                )
                if args.decision != derived_decision:
                    raise SystemExit(
                        f"adaptive decision is derived as {derived_decision!r}; "
                        f"CLI asserted {args.decision!r}"
                    )
            else:
                validate_cross_review_finalization(run_dir, round_doc, args.decision)

        round_doc["status"] = round_status
        round_doc.setdefault("synthesis", {})["next_round_decision"] = args.decision
        if args.blocked or args.decision == "stop":
            round_doc["synthesis"]["stop_reason"] = args.summary
        else:
            round_doc["synthesis"]["next_round_question"] = args.summary
        timestamp = now_iso()
        round_doc["finalized_at"] = timestamp
        round_doc["updated_at"] = timestamp
        append_canonical_event(round_doc, requested_event, timestamp)
        publish_round_mutation("finalize-round", run_dir, round_doc)

        print(run_dir / "state.json")
    return 0


def command_status(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    if not run_dir.is_dir():
        raise SystemExit(f"run directory does not exist: {run_dir}")

    with run_lock(run_dir):
        reconcile_run(run_dir)
        state = load_state(run_dir)
        rounds: dict[str, Any] = {}
        for round_doc in load_all_rounds(run_dir):
            stem = f"round-{int(round_doc['round']):02d}"
            rounds[stem] = {
                "status": round_doc.get("status"),
                **round_counts(round_doc),
            }
        print(
            json.dumps(
                {"run_dir": str(run_dir), **state, "rounds": rounds},
                indent=2,
                ensure_ascii=False,
            )
        )
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Create and validate ledgers for orchestrated multi-agent analysis.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    init = subparsers.add_parser("init", help="Create a new run record.")
    init.add_argument("--root", required=True, help="Run record root directory.")
    init.add_argument("--mode", required=True, choices=["review", "divergent-analysis"])
    init.add_argument("--target", required=True)
    init.add_argument("--target-overlay", choices=["engineering"], default="")
    init.add_argument("--objective", required=True)
    init.add_argument("--spawn-tool", required=True)
    init.add_argument("--wait-tool", required=True)
    init.add_argument("--close-tool", required=True)
    init.add_argument("--cwd", default="")
    init.add_argument("--title", default="")
    init.add_argument("--constraint", action="append", default=[])
    init.add_argument("--source", action="append", default=[])
    init.set_defaults(func=command_init)

    prepare = subparsers.add_parser("prepare-round", help="Validate assignments and create round files.")
    prepare.add_argument("--run-dir", required=True)
    prepare.add_argument("--round", required=True, type=int)
    prepare.add_argument("--assignments", required=True)
    prepare.add_argument("--user-approved", action="store_true")
    prepare.set_defaults(func=command_prepare_round)

    plan_dispatch = subparsers.add_parser(
        "plan-dispatch",
        help="Record dispatch intent before an external worker spawn.",
    )
    plan_dispatch.add_argument("--run-dir", required=True)
    plan_dispatch.add_argument("--round", required=True, type=int)
    plan_dispatch.add_argument("--slot", required=True)
    plan_dispatch.set_defaults(func=command_plan_dispatch)

    for name, event in [
        ("record-spawn", "spawn"),
        ("record-result", "result"),
        ("record-close", "close"),
    ]:
        record = subparsers.add_parser(name, help=f"Record a {event} lifecycle event.")
        record.add_argument("--run-dir", required=True)
        record.add_argument("--round", required=True, type=int)
        record.add_argument("--slot", required=True)
        record.add_argument("--status", required=True)
        record.add_argument("--agent-id", default="")
        record.add_argument("--summary", default="")
        record.set_defaults(func=lambda args, event=event: command_record(args, event))

    synthesis = subparsers.add_parser("record-synthesis", help="Merge structured synthesis into a round.")
    synthesis.add_argument("--run-dir", required=True)
    synthesis.add_argument("--round", required=True, type=int)
    synthesis.add_argument("--synthesis", required=True, help="Path to synthesis JSON object.")
    synthesis.set_defaults(func=command_record_synthesis)

    finalize = subparsers.add_parser("finalize-round", help="Mark synthesis decision for a round.")
    finalize.add_argument("--run-dir", required=True)
    finalize.add_argument("--round", required=True, type=int)
    finalize.add_argument("--decision", required=True, choices=["stop", "continue_round_2", "ask_user"])
    finalize.add_argument("--summary", required=True)
    finalize.add_argument("--blocked", action="store_true")
    finalize.set_defaults(func=command_finalize_round)

    status = subparsers.add_parser("status", help="Print resumable run status as JSON.")
    status.add_argument("--run-dir", required=True)
    status.set_defaults(func=command_status)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
